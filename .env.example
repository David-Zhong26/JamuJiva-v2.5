# Frontend (Vite) — also add these in Vercel → Settings → Environment Variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Use sk_test_... for localhost. Rotate any key that was shared publicly.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Price IDs (price_...). Also add all of these on Vercel for production checkout.
STRIPE_PRICE_GOLDEN=price_xxx
STRIPE_PRICE_SPICED=price_xxx
STRIPE_PRICE_MIXED_DUO=price_xxx
STRIPE_PRICE_TWO_GOLDEN=price_xxx
STRIPE_PRICE_TWO_SPICED=price_xxx

# Comma-separated Boston-area zips eligible for delivery
DELIVERY_ZIPS=02108,02109,02110

# Where Stripe redirects after payment
# Local: http://localhost:3000
# Vercel Production: https://www.jivalivin.com
CLIENT_URL=http://localhost:3000
API_PORT=3001
