# Copy to .env and fill in values. Never commit .env.

# Frontend (Vite) — also add these in Vercel → Settings → Environment Variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Use sk_test_... for localhost. Rotate any key that was shared publicly.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Product IDs (prod_...). Checkout uses each product's default Price.
STRIPE_PRODUCT_GOLDEN=prod_xxx
STRIPE_PRODUCT_SPICED=prod_xxx
STRIPE_PRODUCT_MIXED_DUO=prod_xxx
STRIPE_PRODUCT_TWO_GOLDEN=prod_xxx
STRIPE_PRODUCT_TWO_SPICED=prod_xxx

# Comma-separated Boston-area zips eligible for delivery
DELIVERY_ZIPS=02108,02109,02110

# Where Stripe redirects after payment (localhost for dev)
CLIENT_URL=http://localhost:3000
API_PORT=3001
